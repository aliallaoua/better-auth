{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"tabWidth": 2,
	"printWidth": 80,
	"semi": true,
	"singleQuote": false,
	"jsxSingleQuote": false,
	"quoteProps": "as-needed",
	"trailingComma": "es5",
	"arrowParens": "always",
	"bracketSpacing": true,
	"bracketSameLine": false,
	"endOfLine": "lf",
	"ignorePatterns": [
		"**/src/routeTree.gen.ts",
		"**/src/components/ui/**",
		"**/src/hooks/use-mobile.ts",
		"**/migrations/**",
		"dist",
		"node_modules",
		"bun.lock",
	],
}
